---
// RecentCases — displays California legal cases with AI assistant commentary
// Props:
//   limit - if set, only shows the latest N cases (for homepage)
//   showViewAll - if true, shows a "View All" link when limited (for homepage)

import { cases, type CaseItem } from '../data/cases';

export interface Props {
  limit?: number;
  showViewAll?: boolean;
}

const { limit, showViewAll = false } = Astro.props;
const displayCases = limit ? cases.slice(0, limit) : cases;
const isLimited = limit !== undefined && cases.length > limit;
---

<section class="bg-gray-50 py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2">
          Recent California Cases
        </h2>
        <p class="text-gray-600 max-w-2xl">
          Real cases from California courts — see how the law applies in practice and
          what these rulings mean for you.
        </p>
      </div>
      {
        showViewAll && (
          <a
            href="/recent-cases"
            class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-blue-700 transition-colors no-underline flex-shrink-0"
          >
            View All Cases
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        )
      }
    </div>

    <div class="space-y-8">
      {
        displayCases.map((c: CaseItem) => (
          <article class="bg-white rounded-xl border border-border shadow-sm overflow-hidden">
            {/* Header */}
            <div class="border-b border-border bg-gray-50/50 px-6 py-4">
              <div class="flex flex-wrap items-start gap-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent/10 text-accent">
                  {c.topic}
                </span>
                <span class="text-xs text-gray-500 mt-0.5">{c.court} &middot; {c.date}</span>
              </div>
              <h3 class="text-lg font-semibold text-primary mt-2">{c.name}</h3>
            </div>

            {/* Body */}
            <div class="px-6 py-5 space-y-4">
              <div>
                <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Case Summary</h4>
                <p class="text-sm text-gray-700 leading-relaxed">{c.summary}</p>
                {
                  c.links.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {c.links.map((link) => (
                        <a
                          href={link.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-gray-600 bg-gray-100 rounded-md hover:bg-gray-200 hover:text-gray-800 transition-colors no-underline"
                        >
                          <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )
                }
              </div>

              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                <h4 class="text-xs font-semibold uppercase tracking-wider text-yellow-700 mb-1">Key Takeaway</h4>
                <p class="text-sm text-yellow-800">{c.takeaway}</p>
              </div>

              {/* AI Assistant CTA */}
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                <div class="flex items-start gap-3">
                  <span class="text-xl flex-shrink-0 mt-0.5">🤖</span>
                  <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-blue-700 mb-1">
                      Ask AI Assistant
                    </h4>
                    <p class="text-sm text-blue-800 mb-2">
                      This case raises complex legal questions. Instead of spending hours
                      reading legal documents, ask our AI assistant to explain how this
                      ruling might apply to your situation:
                    </p>
                    <div class="bg-white border border-blue-200 rounded-lg p-3 mb-3">
                      <p class="text-sm text-gray-600 italic">
                        "{c.question}"
                      </p>
                    </div>
                    <a
                      href="/ai-assistant"
                      class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-700 hover:text-blue-800 transition-colors"
                    >
                      Ask this question now
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    {
      isLimited && (
        <div class="text-center mt-8 sm:hidden">
          <a
            href="/recent-cases"
            class="inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-blue-700 transition-colors"
          >
            View All Cases ({cases.length} total)
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      )
    }

    <!-- Bottom CTA -->
    <div class="text-center mt-10">
      <p class="text-gray-600 mb-4">
        California law changes constantly through new court rulings.
        Stay informed and get personalized answers.
      </p>
      <a
        href="/ai-assistant"
        class="inline-flex items-center px-6 py-3 bg-accent text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
      >
        Ask the AI Legal Assistant
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
