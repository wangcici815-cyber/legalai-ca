---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { organizationSchema, breadcrumbSchema } from '../utils/schema';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs?: { name: string; url: string }[];
  noIndex?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  breadcrumbs,
  noIndex = false,
  ogImage,
} = Astro.props;

const siteUrl = 'https://legalai-ca.top';
const pageTitle = `${title} | LegalAI CA`;
const pageCanonical = canonical ? `${siteUrl}${canonical}` : undefined;
const pageOgImage = ogImage || `${siteUrl}/og-image.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageCanonical || siteUrl} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={pageOgImage} />

    {/* Canonical */}
    {pageCanonical && <link rel="canonical" href={pageCanonical} />}

    {/* Robots */}
    {noIndex && <meta name="robots" content="noindex" />}

    {/* JSON-LD Structured Data */}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema())} />
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <!-- Google Search Console — replace with your verification meta tag -->
    <!-- <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" /> -->

    <!-- Bing Webmaster Tools -->
    <meta name="msvalidate.01" content="FEF113AE208213DC3A7AC33024BB7401" />

    <!-- Google tag (gtag.js) - GA4 — replace G-DNWGK3WHHY with your ID -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DNWGK3WHHY"></script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DNWGK3WHHY"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DNWGK3WHHY');
    </script>

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x2ji1rqcfo");
    </script>

    <!-- ============================================= -->
    <!-- 🚀 GOOGLE ADSENSE — UNCOMMENT WHEN APPROVED    -->
    <!-- Get your code from:                            -->
    <!-- https://adsense.google.com → Ads → Get code   -->
    <!-- ============================================= -->
    <!--
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
      crossorigin="anonymous"></script>
    -->
    <!-- ========================================= -->
    <!-- Article meta — injected by ArticleLayout -->
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
