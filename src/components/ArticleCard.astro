---
// Article Card — used on homepage and topic pages
export interface Props {
  title: string;
  description: string;
  href: string;
  date?: string;
  topic?: string;
}

const { title, description, href, date, topic } = Astro.props;
---

<a
  href={href}
  class="block p-6 bg-white rounded-xl border border-border shadow-sm hover:shadow-md hover:border-accent transition-all no-underline group"
>
  <div class="flex items-center gap-2 text-xs text-gray-500 mb-2">
    {topic && (
      <span class="px-2 py-0.5 bg-blue-50 text-accent rounded-full font-medium">{topic}</span>
    )}
    {date && <span>{date}</span>}
  </div>
  <h3 class="text-lg font-semibold text-primary group-hover:text-accent transition-colors mb-2">
    {title}
  </h3>
  <p class="text-sm text-gray-600 leading-relaxed line-clamp-2">{description}</p>
</a>
