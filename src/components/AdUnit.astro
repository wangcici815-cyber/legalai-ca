---
// Google AdSense Ad Unit — SEO-safe placeholder
//
// Renders empty containers to preserve layout space.
// No visible text, borders, or backgrounds — zero content weight.
//
// To activate:
// 1. Uncomment the AdSense script in BaseLayout.astro <head>
// 2. Replace data-ad-slot with your real ad unit ID
// 3. The data-ad-* attributes will be applied automatically

export interface Props {
  /** Ad format: 'banner' (728x90), 'responsive', 'in-article', 'multiplex' */
  format?: 'banner' | 'responsive' | 'rectangle' | 'in-article';
  /** Your Google AdSense ad unit ID (without 'ca-pub-' prefix) */
  slot?: string;
  /** Additional CSS classes */
  class?: string;
}

const { format = 'responsive', slot = 'YOUR_AD_SLOT_ID', class: className = '' } = Astro.props;

// Size classes per format — preserves layout space when ads are activated
const sizeClasses: Record<string, string> = {
  banner: 'min-h-[90px] md:min-h-[90px]',
  responsive: 'min-h-[1px]',   // minimal — Google fills the space
  rectangle: 'min-h-[1px]',     // minimal — Google fills the space
  'in-article': 'min-h-[1px]',  // minimal — Google fills the space
};
---

<!-- AdSense container — empty placeholder, no content weight -->
<div
  class="ad-unit w-full my-6 flex justify-center {sizeClasses[format]} {className}"
  data-ad-format={format}
  data-ad-slot={slot}
  data-full-width-responsive="true"
  aria-hidden="true"
></div>
