---
import BaseLayout from './BaseLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs?: { name: string; url: string }[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonical,
  breadcrumbs,
  noIndex,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={breadcrumbs}
  {noIndex}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {/* Breadcrumb */}
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
        {breadcrumbs.map((crumb, i) => (
          <span>
            {i > 0 && <span class="mx-2">›</span>}
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-accent no-underline">{crumb.name}</a>
            ) : (
              <span class="text-gray-800">{crumb.name}</span>
            )}
          </span>
        ))}
      </nav>
    )}

    <h1 class="text-3xl sm:text-4xl font-bold text-primary mb-4">{title}</h1>
    <p class="text-lg text-gray-600 mb-8">{description}</p>

    {/* Tool content */}
    <div class="bg-white rounded-xl border border-border shadow-sm p-6 sm:p-8 mb-8">
      <slot />
    </div>

    {/* Disclaimer */}
    <Disclaimer />
  </div>
</BaseLayout>
