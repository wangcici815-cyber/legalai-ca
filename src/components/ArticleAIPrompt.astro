---
// ArticleAIPrompt — AI assistant prompt section for article footers
// Shows topic-relevant questions and a CTA to ask the AI assistant
// Props:
//   topic: the legal topic (used to determine questions)
//   questions?: custom questions (overrides auto-generated)
//   label?: custom label

export interface Props {
  topic?: string;
  questions?: string[];
  label?: string;
}

const { topic = '', questions: customQs, label } = Astro.props;

// Auto-generated questions by topic
const topicQuestions: Record<string, string[]> = {
  divorce: [
    'My spouse does not agree to the divorce. What can I do?',
    'Do I need a lawyer to file for divorce in California?',
    'How long does a California divorce take from start to finish?',
  ],
  'child support': [
    'What happens if the other parent hides their income?',
    'Can I modify a child support order without going to court?',
    'How is self-employment income treated for child support?',
  ],
  'spousal support': [
    'How long will I have to pay spousal support for a 15-year marriage?',
    'Can spousal support be modified if I lose my job?',
    'Is spousal support taxable in California?',
  ],
  'landlord': [
    'My landlord is not making repairs. What are my rights?',
    'Can my landlord evict me without a court order?',
    'How much can my landlord increase my rent in California?',
  ],
  tenant: [
    'My landlord is not making repairs. What are my rights?',
    'Can my landlord evict me without a court order?',
    'How much can my landlord increase my rent in California?',
  ],
  will: [
    'Do I need a lawyer to write a will in California?',
    'What happens if I die without a will in California?',
    'How often should I update my will?',
  ],
  estate: [
    'Do I need a lawyer to write a will in California?',
    'What happens if I die without a will in California?',
    'What is the difference between a will and a living trust?',
  ],
  'workers comp': [
    'How do I file a workers compensation claim in California?',
    'What benefits am I entitled to under California workers comp?',
    'Can I choose my own doctor for a workers comp claim?',
  ],
};

const questions = customQs ?? topicQuestions[topic.toLowerCase()] ?? [
  'How does California law apply to my specific situation?',
  'What are my legal rights in this situation?',
  'Do I need a lawyer, or can I handle this myself?',
];

const displayLabel = label ?? `Still have questions about ${topic}?`;
const aiLink = (q: string) => `/ai-assistant?q=${encodeURIComponent(q)}`;
---

<div class="bg-blue-50 border border-blue-200 rounded-xl p-6 my-8">
  <div class="flex items-start gap-4">
    <span class="text-3xl flex-shrink-0 mt-1">🤖</span>
    <div class="min-w-0">
      <h3 class="text-lg font-semibold text-primary mb-1">{displayLabel}</h3>
      <p class="text-sm text-gray-600 mb-4">
        Every situation is different. Ask our AI Legal Assistant for answers
        specific to your circumstances — based on California law.
      </p>

      <div class="space-y-2">
        {
          questions.map((q) => (
            <a
              href={aiLink(q)}
              class="block w-full text-left px-4 py-3 bg-white border border-blue-200 rounded-lg text-sm text-gray-700 hover:border-accent hover:text-accent hover:shadow-sm transition-all no-underline"
            >
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                <span class="line-clamp-2">{q}</span>
                <svg class="w-4 h-4 flex-shrink-0 ml-auto text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>

      <div class="mt-4 pt-3 border-t border-blue-200">
        <a
          href="/ai-assistant"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-blue-700 transition-colors"
        >
          Ask your own question →
        </a>
      </div>
    </div>
  </div>
</div>
