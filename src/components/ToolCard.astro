---
// Tool Card — used on homepage and topic pages
export interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon = '🔧' } = Astro.props;
---

<a
  href={href}
  class="block p-6 bg-white rounded-xl border border-border shadow-sm hover:shadow-md hover:border-accent transition-all no-underline group"
>
  <span class="text-3xl mb-3 block">{icon}</span>
  <h3 class="text-lg font-semibold text-primary group-hover:text-accent transition-colors mb-2">
    {title}
  </h3>
  <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
</a>
