---
import ToolLayout from '../layouts/ToolLayout.astro';
import ChildSupportCalculator from '../components/ChildSupportCalculator';
---

<ToolLayout
  title="California Child Support Calculator"
  description="Estimate monthly child support payments using the California Guideline formula (Family Code §4055). Free, no sign-up required."
  canonical="/child-support-calculator"
  breadcrumbs={[
    { name: 'Home', url: 'https://legalai-ca.top/' },
    { name: 'Child Support Calculator', url: 'https://legalai-ca.top/child-support-calculator' },
  ]}
>
  <p class="text-gray-600 mb-6">
    This calculator estimates child support based on the California guideline formula.
    Enter your financial information below for an approximate calculation.
  </p>

  <ChildSupportCalculator client:load />

  <div class="mt-8 p-4 bg-blue-50 border border-blue-200 rounded-lg">
    <h3 class="font-semibold text-primary mb-2">How This Calculator Works</h3>
    <p class="text-sm text-gray-700 leading-relaxed">
      This calculator uses the California guideline formula established in Family Code §4055.
      It estimates each parent's net income (after estimated taxes and deductions), applies
      the income shares model, adjusts for parenting time, and calculates the base support
      amount. Health insurance and childcare costs are added proportionally.
    </p>
    <p class="text-sm text-gray-700 mt-2">
      <strong>Reference:</strong> California Family Code §§4050-4076
      | <a href="https://www.childsupport.ca.gov/guideline-calculator/" class="text-accent underline" rel="noopener noreferrer">CA Child Support Services</a>
    </p>
  </div>

  <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
    <h3 class="font-semibold text-yellow-800 mb-2">⚠️ Important Notes</h3>
    <ul class="text-sm text-yellow-700 space-y-1 list-disc pl-4">
      <li>This is an <strong>estimate only</strong>. Actual court-ordered support may differ.</li>
      <li>The court may deviate from the guideline for high-income parents (combined net income over $10,000/month).</li>
      <li>Tax deductions are estimated — actual tax situations vary.</li>
      <li>Consult a licensed California attorney for legal advice about your specific situation.</li>
    </ul>
  </div>

  <div class="mt-6">
    <h3 class="font-semibold text-primary mb-2">Related Resources</h3>
    <ul class="text-sm space-y-1">
      <li><a href="/guides/california-child-support-guide" class="text-accent underline">California Child Support Guide</a> — Full guide to how support is calculated</li>
      <li><a href="/alimony-estimator" class="text-accent underline">Alimony Estimator</a> — Estimate spousal support</li>
      <li><a href="/ai-assistant" class="text-accent underline">AI Legal Assistant</a> — Ask questions about California family law</li>
    </ul>
  </div>
</ToolLayout>
