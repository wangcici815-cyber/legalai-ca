// Hero Section — homepage top
---

<section class="bg-gradient-to-br from-primary to-blue-900 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight">
      California Legal Information<br />
      <span class="text-blue-300">Made Simple</span>
    </h1>
    <p class="text-lg sm:text-xl text-blue-200 mb-8 max-w-2xl mx-auto leading-relaxed">
      Free guides, calculators, and AI-powered help for California family law,
      landlord-tenant issues, estate planning, and more.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/ai-assistant" class="btn-primary text-lg">
        Ask AI Assistant
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="/child-support-calculator" class="btn-secondary border-white text-white hover:bg-white hover:text-primary">
