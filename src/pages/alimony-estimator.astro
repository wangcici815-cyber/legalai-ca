---
import ToolLayout from '../layouts/ToolLayout.astro';
import AlimonyEstimator from '../components/AlimonyEstimator';
---

<ToolLayout
  title="California Alimony (Spousal Support) Estimator"
  description="Estimate spousal support payments in California. Free calculator based on common county guidelines and Family Code §4320 factors."
  canonical="/alimony-estimator"
  breadcrumbs={[
    { name: 'Home', url: 'https://legalai-ca.pages.dev/' },
    { name: 'Alimony Estimator', url: 'https://legalai-ca.pages.dev/alimony-estimator' },
  ]}
>
  <p class="text-gray-600 mb-6">
    Estimate spousal support (alimony) based on income differences, marriage duration,
    and common California county guidelines. This is a rough estimate — actual amounts
    depend on the 12 factors in Family Code §4320.
  </p>

  <AlimonyEstimator client:load />

  <div class="mt-8 p-4 bg-blue-50 border border-blue-200 rounded-lg">
    <h3 class="font-semibold text-primary mb-2">How This Estimator Works</h3>
    <p class="text-sm text-gray-700 leading-relaxed">
      This estimator uses the Santa Clara guideline (40% of higher earner's net income
      minus 50% of lower earner's net income), which many California counties use as a
      reference for temporary spousal support. Duration is estimated based on marriage
      length: short-term marriages (under 10 years) typically receive support for half
      the marriage duration; long-term marriages may receive indefinite support.
    </p>
    <p class="text-sm text-gray-700 mt-2">
      <strong>Reference:</strong> California Family Code §4320 (12 factors for spousal support)
    </p>
  </div>

  <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
    <h3 class="font-semibold text-yellow-800 mb-2">⚠️ Important Notes</h3>
    <ul class="text-sm text-yellow-700 space-y-1 list-disc pl-4">
      <li>This is an <strong>estimate only</strong>. Actual court-ordered support varies significantly.</li>
      <li>Permanent spousal support has no fixed formula — judges have broad discretion.</li>
      <li>Spousal support is separate from child support. Both may be ordered in the same case.</li>
      <li>Tax treatment: For divorces after 2018, spousal support is neither deductible nor taxable.</li>
      <li>Consult a licensed California attorney for legal advice about your specific situation.</li>
    </ul>
  </div>

  <div class="mt-6">
    <h3 class="font-semibold text-primary mb-2">Related Resources</h3>
    <ul class="text-sm space-y-1">
      <li><a href="/guides/california-spousal-support-guide" class="text-accent underline">California Spousal Support Guide</a> — Full guide to alimony laws</li>
      <li><a href="/child-support-calculator" class="text-accent underline">Child Support Calculator</a> — Estimate child support</li>
      <li><a href="/ai-assistant" class="text-accent underline">AI Legal Assistant</a> — Ask questions about California family law</li>
    </ul>
  </div>
</ToolLayout>
